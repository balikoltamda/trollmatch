# Balık Oltamda Guide — environment variable reference (ui/)
#
# Next.js loads files in this order (later overrides earlier):
#   1. .env
#   2. .env.local          <- secrets (never commit)
#   3. .env.development    <- dev defaults (committed)
#   4. .env.development.local
#
# Production uses .env.production and .env.production.local instead.
#
# Quick start:
#   cp .env.example .env.local
#   npm run db:up && npm run db:migrate && npm run db:check

NODE_ENV=development
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Copy to .env.local (secrets):
# DATABASE_URL=postgresql://trollmatch:trollmatch@localhost:5432/trollmatch
