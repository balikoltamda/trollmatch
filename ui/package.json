{
  "name": "ui",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build && node scripts/prepare-standalone.mjs",
    "start": "next start",
    "lint": "npx eslint .",
    "lint:fix": "npx eslint . --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:check": "tsx scripts/verify-db.ts",
    "db:status": "prisma migrate status",
    "import": "tsx scripts/run-import.ts",
    "import:batch": "tsx scripts/run-import-batch.ts",
    "import:demo": "tsx src/modules/import/providers/demo/demo-importer.ts",
    "import:duel:fetch": "tsx src/modules/import/providers/duel/duel-fetcher.ts",
    "import:duel:parse": "tsx src/modules/import/providers/duel/duel-parser.ts",
    "import:duel:run": "tsx scripts/run-import.ts --manufacturer duel",
    "import:run": "tsx scripts/run-import.ts",
    "backfill:editorial-imports": "tsx scripts/backfill-editorial-imports.ts",
    "backfill:image-urls": "tsx scripts/backfill-image-urls.ts",
    "backfill:media-assets": "tsx scripts/backfill-media-assets.ts",
    "postinstall": "prisma generate",
    "test:middleware": "tsx --test src/middleware.test.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.22.0",
    "next": "15.5.19",
    "next-auth": "^5.0.0-beta.25",
    "next-intl": "^4.13.1",
    "pg": "^8.22.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "shadcn": "^4.12.0",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "15.5.19",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.9.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
