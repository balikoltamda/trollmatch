  lureModel   LureModel   @relation(fields: [lureModelId], references: [id], onDelete: Cascade)
  fishSpecies FishSpecies @relation(fields: [fishSpeciesId], references: [id], onDelete: Restrict)

  @@unique([lureModelId, fishSpeciesId, associationKind])
  @@index([lureModelId])
  @@index([fishSpeciesId])
  @@index([associationKind])
  @@index([deletedAt])
  @@map("lure_species")
}

// ---------------------------------------------------------------------------
// Canonical product identity (Sprint Foundation F001)
// ---------------------------------------------------------------------------

/// Canonical color — normalized colorway referenced by every lure variant.
model Color {
  id        String    @id @default(uuid()) @db.Uuid
  slug      String    @unique @db.VarChar(128)
  nameEn    String    @map("name_en") @db.VarChar(256)
  nameTr    String    @map("name_tr") @db.VarChar(256)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  aliases  ColorAlias[]
  variants LureVariant[]

  @@index([deletedAt])
  @@map("colors")
}

/// Alternate name or code for a canonical color (manufacturer codes, regional names, search terms).
model ColorAlias {
  id                String         @id @default(uuid()) @db.Uuid
  colorId           String         @map("color_id") @db.Uuid
  manufacturerId    String?        @map("manufacturer_id") @db.Uuid
  /// Uniqueness scope: manufacturer UUID or literal `platform` when manufacturerId is null.
  manufacturerScope String         @default("platform") @map("manufacturer_scope") @db.VarChar(36)
  /// Locale code (`tr`, `en`) or `any` for locale-invariant aliases (e.g. manufacturer SKU codes).
  locale            String         @default("any") @db.VarChar(8)
  alias             String         @db.VarChar(512)
  aliasNormalized   String         @map("alias_normalized") @db.VarChar(512)
  kind              ColorAliasKind @default(MANUFACTURER_CODE)
  createdAt         DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt         DateTime?      @map("deleted_at") @db.Timestamptz(6)

  color        Color         @relation(fields: [colorId], references: [id], onDelete: Cascade)
  manufacturer Manufacturer? @relation(fields: [manufacturerId], references: [id], onDelete: SetNull)

  @@unique([aliasNormalized, locale, manufacturerScope])
  @@index([colorId])
  @@index([manufacturerId])
  @@index([locale])
  @@index([kind])
  @@index([deletedAt])
  @@map("color_aliases")
}

/// Alternate name or identifier for a lure model (model codes, marketing names, search terms).
model ProductAlias {
  id                String           @id @default(uuid()) @db.Uuid
  lureModelId       String           @map("lure_model_id") @db.Uuid
  manufacturerId    String?          @map("manufacturer_id") @db.Uuid
  /// Uniqueness scope: manufacturer UUID or literal `platform` when manufacturerId is null.
  manufacturerScope String           @default("platform") @map("manufacturer_scope") @db.VarChar(36)
  /// Locale code (`tr`, `en`) or `any` for locale-invariant aliases (e.g. manufacturer model codes).
  locale            String           @default("any") @db.VarChar(8)
  alias             String           @db.VarChar(512)
  aliasNormalized   String           @map("alias_normalized") @db.VarChar(512)
  kind              ProductAliasKind @default(DISPLAY_NAME)
  createdAt         DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt         DateTime?        @map("deleted_at") @db.Timestamptz(6)

