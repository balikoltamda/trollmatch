generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Shared enums (minimal — expanded in later sprints per 007_DATABASE_VISION.md)
// ---------------------------------------------------------------------------

enum ContentLifecycleState {
  DRAFT
  PENDING_REVIEW
  READY
  PUBLISHED
  DEPRECATED
  REJECTED
  ARCHIVED

  @@map("content_lifecycle_state")
}

enum LureSpeciesAssociationKind {
  MANUFACTURER_MARKETING
  MODERATOR_CURATED
  COMMUNITY_EFFECTIVENESS

  @@map("lure_species_association_kind")
}

enum ImageRole {
  HERO
  PRODUCT
  GALLERY
  PACKAGING
  TECHNOLOGY
  HOOK_DETAIL
  SPLIT_RING_DETAIL
  COLOR_CARD
  ACTION_DIAGRAM
  RIGGING_DIAGRAM
  TECHNICAL_DIAGRAM
  UNKNOWN

  @@map("image_role")
}

/// Digital twin sync state — manufacturer page vs catalog alignment.
enum DigitalTwinSyncStatus {
  NEVER_SYNCED
  SYNCED
  STALE
  CHANGES_PENDING
  CHECK_FAILED

  @@map("digital_twin_sync_status")
}

/// Classification for manufacturer sync diffs.
enum ImportFieldChangeKind {
  ADDED
  UPDATED
  REMOVED
  UNCHANGED

  @@map("import_field_change_kind")
}

enum ProductAliasKind {
  DISPLAY_NAME
  MODEL_CODE
  MARKETING_NAME
  SEARCH_TERM

  @@map("product_alias_kind")
}

enum ColorAliasKind {
  MANUFACTURER_CODE
  MARKETING_NAME
  SEARCH_TERM

  @@map("color_alias_kind")
}

enum SpeciesAliasKind {
  SEARCH_TERM
  REGIONAL_NAME
  MISSPELLING
  SYNONYM

  @@map("species_alias_kind")
}

/// IUCN Red List category — optional on SpeciesProfile.
enum IucnRedListStatus {
  LC
  NT
  VU
  EN
  CR
  DD
  NE
  EW
  EX

  @@map("iucn_red_list_status")
}

enum SpeciesImageRole {
  HERO
  GALLERY

  @@map("species_image_role")
}

enum ManufacturerImageRole {
  LOGO

  @@map("manufacturer_image_role")
}

/// Optimized derivative sizes for a managed media asset.
enum MediaAssetVariantKind {
  ORIGINAL
  LARGE
  MEDIUM
  THUMBNAIL
  WEBP

  @@map("media_asset_variant_kind")
}

/// Manufacturer feed presence — distinct from editorial ContentLifecycleState (Sprint S014).
enum ManufacturerProductStatus {
  ACTIVE
  MISSING
  DISCONTINUED
  UNKNOWN

  @@map("manufacturer_product_status")
}

/// Studio access role — ADMIN supersedes EDITOR and MODERATOR permissions in app code.
enum StudioRole {
  ADMIN
  EDITOR
  MODERATOR

  @@map("studio_role")
}

/// Editorial confidence for Balık Oltamda field notes (Studio).
enum EditorNoteConfidence {
  LOW
  MEDIUM
  HIGH

  @@map("editor_note_confidence")
}

/// Import batch lifecycle for Studio Import Center.
enum ImportBatchStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED

  @@map("import_batch_status")
}

/// Audit action categories for catalog change history.
enum CatalogAuditAction {
  IMPORT_BATCH
  IMPORT_CREATE
  IMPORT_UPDATE
  IMPORT_DIFF
  EDITOR_CANONICAL
  EDITOR_NOTES
  LIFECYCLE_CHANGE
  PUBLISH
  UNPUBLISH
  BULK_ACTION
  SUGGESTION_APPROVE
  SUGGESTION_REJECT
  SUGGESTION_CORRECT
  SUGGESTION_MERGE
  AI_SUGGESTION_ACCEPT
  AI_SUGGESTION_REJECT
  NOTIFICATION_REVIEW
  NOTIFICATION_REVIEW_CATEGORY
  NOTIFICATION_REVIEW_ALL

  @@map("catalog_audit_action")
}

/// Status of an angler-submitted catch report in the moderation pipeline.
enum CatchReportVerificationStatus {
  PENDING
  APPROVED
  REJECTED
  MERGED

  @@map("catch_report_verification_status")
}

/// Where the angler was fishing when the catch occurred.
enum BoatOrShore {
  BOAT
  SHORE

  @@map("boat_or_shore")
}

/// Knowledge acquisition source type (Sprint 7.4+ — no crawlers yet).
enum KnowledgeSourceType {
  MANUFACTURER
  COMMUNITY
  YOUTUBE
  FISHING_FORUM
  FISHING_BLOG
  PUBLIC_ARTICLE
  MAGAZINE
  SCIENTIFIC_PUBLICATION
  OTHER

  @@map("knowledge_source_type")
}

/// Lifecycle of a discovered knowledge item in the editorial inbox.
enum KnowledgeItemStatus {
  DISCOVERED
  PENDING_REVIEW
  APPROVED
  REJECTED
  MERGED
  IGNORED
  DUPLICATE
  ARCHIVED
  OUTDATED

  @@map("knowledge_item_status")
}

enum KnowledgeEditorDecision {
  NONE
  APPROVED
  REJECTED
  MERGED
  IGNORED
  ARCHIVED
  OUTDATED

  @@map("knowledge_editor_decision")
}

enum KnowledgeConfidence {
  LOW
  MEDIUM
  HIGH

  @@map("knowledge_confidence")
}

enum KnowledgeAuditAction {
  APPROVE
  REJECT
  MERGE
  IGNORE
  OPEN_SOURCE
  ARCHIVE
  FLAG_OUTDATED

  @@map("knowledge_audit_action")
}

enum KnowledgeGraphEntityType {
  SPECIES
  LURE_MODEL
  MANUFACTURER
  TECHNIQUE
  KNOWLEDGE_ITEM

  @@map("knowledge_graph_entity_type")
}

enum KnowledgeGraphRelationKind {
  MENTIONS
  SUPPORTS
  CONFLICTS_WITH
  DUPLICATE_OF
  RELATED_TO

  @@map("knowledge_graph_relation_kind")
}

/// Provenance of a catalog suggestion awaiting editorial verification.
enum SuggestionSource {
  IMPORTER
  AI_ENRICHMENT
  COMMUNITY_REPORT
  AI_SUMMARY
  EDITOR

  @@map("suggestion_source")
}

/// Lifecycle of a verification suggestion.
enum SuggestionStatus {
  PENDING
  APPROVED
  REJECTED
  MERGED
  SUPERSEDED

  @@map("suggestion_status")
}

/// What kind of catalog change a suggestion proposes.
enum SuggestionKind {
  FIELD_VALUE
  SPECIES_LINK
  TECHNIQUE_LINK
  EDITOR_NOTE
  IMAGE_COVER
  SUMMARY
  MERGE_CANDIDATE

  @@map("suggestion_kind")
}

/// Pending importer field changes — editors accept or reject before reverting.
enum ImportFieldChangeStatus {
  PENDING
  ACCEPTED
  REJECTED

  @@map("import_field_change_status")
}

// ---------------------------------------------------------------------------
// LureAtlas catalog core (Sprint 2.1 — not the final long-horizon model)
// ---------------------------------------------------------------------------

/// Manufacturer — catalog owner (LureAtlas Manufacturer facade, L4).
model Manufacturer {
  id          String    @id @default(uuid()) @db.Uuid
  slug        String    @unique @db.VarChar(128)
  nameEn      String    @map("name_en") @db.VarChar(256)
  nameTr      String    @map("name_tr") @db.VarChar(256)
  countryCode String?   @map("country_code") @db.Char(2)
  website     String?   @db.VarChar(512)
  logoUrl     String?   @map("logo_url") @db.VarChar(1024)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)

  productLines  ProductLine[]
  lureModels    LureModel[]
  productAliases ProductAlias[]
  colorAliases  ColorAlias[]
  importBatches ImportBatch[]
  knowledgeItems KnowledgeItem[]
  images        ManufacturerImage[]
  technologies  ManufacturerTechnology[]
  mediaAssets   MediaAsset[]

  @@index([deletedAt])
  @@map("manufacturers")
}

/// Product line — manufacturer series grouping multiple lure models.
model ProductLine {
  id             String    @id @default(uuid()) @db.Uuid
  manufacturerId String    @map("manufacturer_id") @db.Uuid
  slug           String    @db.VarChar(128)
  nameEn         String    @map("name_en") @db.VarChar(256)
  nameTr         String    @map("name_tr") @db.VarChar(256)
  descriptionEn  String?   @map("description_en") @db.Text
  descriptionTr  String?   @map("description_tr") @db.Text
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz(6)

  manufacturer Manufacturer @relation(fields: [manufacturerId], references: [id], onDelete: Restrict)
  lureModels   LureModel[]

  @@unique([manufacturerId, slug])
  @@index([manufacturerId])
  @@index([deletedAt])
  @@map("product_lines")
}

/// LureAtlas Model — canonical lure design (all variants share core identity).
model LureModel {
  id                String                @id @default(uuid()) @db.Uuid
  manufacturerId    String                @map("manufacturer_id") @db.Uuid
  productLineId     String                @map("product_line_id") @db.Uuid
  slug              String                @unique @db.VarChar(128)
  nameEn            String                @map("name_en") @db.VarChar(256)
  nameTr            String                @map("name_tr") @db.VarChar(256)
  formFactorEn      String?               @map("form_factor_en") @db.VarChar(128)
  formFactorTr      String?               @map("form_factor_tr") @db.VarChar(128)
  bodyTypeSlug      String?               @map("body_type_slug") @db.VarChar(64)
  bodyTypeEn        String?               @map("body_type_en") @db.VarChar(128)
  bodyTypeTr        String?               @map("body_type_tr") @db.VarChar(128)
  buoyancySlug      String?               @map("buoyancy_slug") @db.VarChar(64)
  buoyancyEn        String?               @map("buoyancy_en") @db.VarChar(128)
  buoyancyTr        String?               @map("buoyancy_tr") @db.VarChar(128)
  divingDepthMinM   Decimal?              @map("diving_depth_min_m") @db.Decimal(6, 2)
  divingDepthMaxM   Decimal?              @map("diving_depth_max_m") @db.Decimal(6, 2)
  trollingSpeedMinKn Decimal?             @map("trolling_speed_min_kn") @db.Decimal(5, 2)
  trollingSpeedMaxKn Decimal?             @map("trolling_speed_max_kn") @db.Decimal(5, 2)
  coatingTypeSlug   String?               @map("coating_type_slug") @db.VarChar(64)
  coatingTypeEn     String?               @map("coating_type_en") @db.VarChar(128)
  coatingTypeTr     String?               @map("coating_type_tr") @db.VarChar(128)
  actionSlug        String?               @map("action_slug") @db.VarChar(64)
  actionEn          String?               @map("action_en") @db.VarChar(128)
  actionTr          String?               @map("action_tr") @db.VarChar(128)
  shortDescriptionEn String?              @map("short_description_en") @db.Text
  shortDescriptionTr String?              @map("short_description_tr") @db.Text
  seoTitleEn         String?              @map("seo_title_en") @db.VarChar(256)
  seoTitleTr         String?              @map("seo_title_tr") @db.VarChar(256)
  metaDescriptionEn  String?              @map("meta_description_en") @db.Text
  metaDescriptionTr  String?              @map("meta_description_tr") @db.Text
  openGraphTitleEn   String?              @map("open_graph_title_en") @db.VarChar(256)
  openGraphTitleTr   String?              @map("open_graph_title_tr") @db.VarChar(256)
  openGraphDescriptionEn String?          @map("open_graph_description_en") @db.Text
  openGraphDescriptionTr String?          @map("open_graph_description_tr") @db.Text
  /// Permanent link to official manufacturer product page (digital twin).
  manufacturerUrl    String?              @map("manufacturer_url") @db.VarChar(1024)
  lastManufacturerSyncAt DateTime?        @map("last_manufacturer_sync_at") @db.Timestamptz(6)
  lastManufacturerCheckAt DateTime?       @map("last_manufacturer_check_at") @db.Timestamptz(6)
  lastSuccessfulImportAt DateTime?       @map("last_successful_import_at") @db.Timestamptz(6)
  manufacturerVersionHash String?           @map("manufacturer_version_hash") @db.Char(64)
  contentHash        String?              @map("content_hash") @db.Char(64)
  imageHash          String?              @map("image_hash") @db.Char(64)
  technologyHash     String?              @map("technology_hash") @db.Char(64)
  specificationHash  String?              @map("specification_hash") @db.Char(64)
  syncStatus         DigitalTwinSyncStatus @default(NEVER_SYNCED) @map("sync_status")
  /// Hooks, split rings, manufacturer notes from import — JSON blob.
  importSpecMetadata Json?                 @map("import_spec_metadata")
  lifecycleState    ContentLifecycleState @default(DRAFT) @map("lifecycle_state")
  /// First observation in a manufacturer import feed (S014).
  firstSeenAt        DateTime?              @map("first_seen_at") @db.Timestamptz(6)
  /// Most recent observation in a manufacturer import feed (S014).
  lastSeenAt         DateTime?              @map("last_seen_at") @db.Timestamptz(6)
  /// Most recent successful catalog import touch (S014).
  lastImportedAt     DateTime?              @map("last_imported_at") @db.Timestamptz(6)
  /// Consecutive import batches where product was absent from feed (S014).
  missingImportCount Int                    @default(0) @map("missing_import_count")
  /// Manufacturer feed presence; never implies row deletion (S014).
  manufacturerStatus ManufacturerProductStatus @default(UNKNOWN) @map("manufacturer_status")
  createdAt         DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime              @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt         DateTime?             @map("deleted_at") @db.Timestamptz(6)

  manufacturer     Manufacturer     @relation(fields: [manufacturerId], references: [id], onDelete: Restrict)
  productLine      ProductLine      @relation(fields: [productLineId], references: [id], onDelete: Restrict)
  variants         LureVariant[]
  images           Image[]
  lureTechniques   LureTechnique[]
  lureSpeciesLinks LureSpecies[]
  aliases          ProductAlias[]
  editorNote          LureEditorNote?
  auditEntries        CatalogAuditEntry[]
  importFieldChanges  ImportFieldChange[]
  catalogSuggestions  CatalogSuggestion[]
  knowledgeItems      KnowledgeItem[]
  technologyLinks     LureModelTechnology[]

  @@index([manufacturerId])
  @@index([productLineId])
  @@index([lifecycleState])
  @@index([manufacturerStatus])
  @@index([deletedAt])
  @@map("lure_models")
}

/// Reusable manufacturer technology (3D Prism Finish, Wave Motion Belly, etc.).
model ManufacturerTechnology {
  id             String   @id @default(uuid()) @db.Uuid
  manufacturerId String   @map("manufacturer_id") @db.Uuid
  slug           String   @db.VarChar(128)
  nameEn         String   @map("name_en") @db.VarChar(256)
  descriptionEn  String?  @map("description_en") @db.Text
  descriptionTr  String?  @map("description_tr") @db.Text
  patentNote     String?  @map("patent_note") @db.Text
  imageUrl       String?  @map("image_url") @db.VarChar(1024)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  manufacturer Manufacturer          @relation(fields: [manufacturerId], references: [id], onDelete: Cascade)
  lureLinks    LureModelTechnology[]
  images       TechnologyImage[]

  @@unique([manufacturerId, slug])
  @@index([manufacturerId])
  @@map("manufacturer_technologies")
}

/// Technology encyclopedia image — patent diagrams, marketing assets.
model TechnologyImage {
  id           String   @id @default(uuid()) @db.Uuid
  technologyId String   @map("technology_id") @db.Uuid
  mediaAssetId String?  @map("media_asset_id") @db.Uuid
  url          String   @db.VarChar(1024)
  altTextEn    String?  @map("alt_text_en") @db.VarChar(512)
  sortOrder    Int      @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  technology ManufacturerTechnology @relation(fields: [technologyId], references: [id], onDelete: Cascade)
  mediaAsset MediaAsset?            @relation(fields: [mediaAssetId], references: [id], onDelete: SetNull)

  @@index([technologyId])
  @@index([mediaAssetId])
  @@map("technology_images")
}

/// Canonical managed media asset — single source of truth for local image storage.
model MediaAsset {
  id             String    @id @default(uuid()) @db.Uuid
  sha256Hash     String    @unique @map("sha256_hash") @db.Char(64)
  originalUrl    String?   @map("original_url") @db.VarChar(1024)
  mimeType       String    @map("mime_type") @db.VarChar(128)
  widthPx        Int?      @map("width_px")
  heightPx       Int?      @map("height_px")
  sizeBytes      Int       @map("size_bytes")
  importedAt     DateTime  @default(now()) @map("imported_at") @db.Timestamptz(6)
  manufacturerId String?   @map("manufacturer_id") @db.Uuid
  creditEn       String?   @map("credit_en") @db.VarChar(512)
  creditTr       String?   @map("credit_tr") @db.VarChar(512)
  photographerEn String?   @map("photographer_en") @db.VarChar(512)
  photographerTr String?   @map("photographer_tr") @db.VarChar(512)
  copyrightEn    String?   @map("copyright_en") @db.VarChar(512)
  copyrightTr    String?   @map("copyright_tr") @db.VarChar(512)
  licenseNoteEn  String?   @map("license_note_en") @db.VarChar(512)
  licenseNoteTr  String?   @map("license_note_tr") @db.VarChar(512)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  manufacturer       Manufacturer?       @relation(fields: [manufacturerId], references: [id], onDelete: SetNull)
  variants           MediaAssetVariant[]
  lureImages         Image[]
  speciesImages      SpeciesImage[]
  manufacturerImages ManufacturerImage[]
  technologyImages   TechnologyImage[]

  @@index([manufacturerId])
  @@index([importedAt])
  @@map("media_assets")
}

/// Derived image file for a MediaAsset (large, medium, thumbnail, WebP).
model MediaAssetVariant {
  id           String                @id @default(uuid()) @db.Uuid
  mediaAssetId String                @map("media_asset_id") @db.Uuid
  kind         MediaAssetVariantKind
  publicPath   String                @map("public_path") @db.VarChar(1024)
  mimeType     String                @map("mime_type") @db.VarChar(128)
  widthPx      Int?                  @map("width_px")
  heightPx     Int?                  @map("height_px")
  sizeBytes    Int                   @map("size_bytes")
  createdAt    DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)

  mediaAsset MediaAsset @relation(fields: [mediaAssetId], references: [id], onDelete: Cascade)

  @@unique([mediaAssetId, kind])
  @@index([mediaAssetId])
  @@map("media_asset_variants")
}

/// Product ↔ technology link — products reference shared technology entities.
model LureModelTechnology {
  id           String   @id @default(uuid()) @db.Uuid
  lureModelId  String   @map("lure_model_id") @db.Uuid
  technologyId String   @map("technology_id") @db.Uuid
  sortOrder    Int      @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  lureModel  LureModel              @relation(fields: [lureModelId], references: [id], onDelete: Cascade)
  technology ManufacturerTechnology @relation(fields: [technologyId], references: [id], onDelete: Cascade)

  @@unique([lureModelId, technologyId])
  @@index([lureModelId])
  @@index([technologyId])
  @@map("lure_model_technologies")
}

/// LureAtlas Variant — SKU-level size / weight / color release.
model LureVariant {
  id          String    @id @default(uuid()) @db.Uuid
  lureModelId String    @map("lure_model_id") @db.Uuid
  colorId     String    @map("color_id") @db.Uuid
  slug        String    @db.VarChar(128)
  labelEn     String    @map("label_en") @db.VarChar(256)
  labelTr     String    @map("label_tr") @db.VarChar(256)
  lengthMm    Int?      @map("length_mm")
  weightG     Int?      @map("weight_g")
  sortOrder   Int       @default(0) @map("sort_order")
  isDefault   Boolean   @default(false) @map("is_default")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)

  lureModel LureModel @relation(fields: [lureModelId], references: [id], onDelete: Cascade)
  color     Color     @relation(fields: [colorId], references: [id], onDelete: Restrict)
  images    Image[]
  catchReports CatchReport[]

  @@unique([lureModelId, slug])
  @@index([lureModelId])
  @@index([colorId])
  @@index([deletedAt])
  @@map("lure_variants")
}

/// Image — media attachment for lure model or variant.
model Image {
  id            String    @id @default(uuid()) @db.Uuid
  lureModelId   String    @map("lure_model_id") @db.Uuid
  lureVariantId String?   @map("lure_variant_id") @db.Uuid
  mediaAssetId  String?   @map("media_asset_id") @db.Uuid
  url           String    @db.VarChar(1024)
  /// Original remote URL when `url` points at locally stored media.
  sourceUrl     String?   @map("source_url") @db.VarChar(1024)
  sha256Hash    String?   @map("sha256_hash") @db.Char(64)
  mimeType      String?   @map("mime_type") @db.VarChar(128)
  widthPx       Int?      @map("width_px")
  heightPx      Int?      @map("height_px")
  altTextEn     String?   @map("alt_text_en") @db.VarChar(512)
  altTextTr     String?   @map("alt_text_tr") @db.VarChar(512)
  creditEn      String?   @map("credit_en") @db.VarChar(512)
  creditTr      String?   @map("credit_tr") @db.VarChar(512)
  copyrightEn   String?   @map("copyright_en") @db.VarChar(512)
  copyrightTr   String?   @map("copyright_tr") @db.VarChar(512)
  role          ImageRole @default(PRODUCT)
  sortOrder     Int       @default(0) @map("sort_order")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz(6)

  lureModel   LureModel    @relation(fields: [lureModelId], references: [id], onDelete: Cascade)
  lureVariant LureVariant? @relation(fields: [lureVariantId], references: [id], onDelete: SetNull)
  mediaAsset  MediaAsset?  @relation(fields: [mediaAssetId], references: [id], onDelete: SetNull)

  @@index([lureModelId])
  @@index([lureVariantId])
  @@index([mediaAssetId])
  @@index([sha256Hash])
  @@index([deletedAt])
  @@map("images")
}

// ---------------------------------------------------------------------------
// Reference taxonomy (simplified facades — full Taxonomy Term layer deferred)
// ---------------------------------------------------------------------------

/// Fish species — platform biological anchor (Fish Species facade, L3).
model FishSpecies {
  id              String    @id @default(uuid()) @db.Uuid
  /// Legacy canonical slug — kept in sync with slugEn for backward compatibility.
  slug            String    @unique @db.VarChar(128)
  slugEn          String    @unique @map("slug_en") @db.VarChar(128)
  slugTr          String    @unique @map("slug_tr") @db.VarChar(128)
  scientificName  String    @map("scientific_name") @db.VarChar(256)
  nameEn          String    @map("name_en") @db.VarChar(256)
  nameTr          String    @map("name_tr") @db.VarChar(256)
  /// Editorial taxonomy notes — not shown as primary label.
  editorialNotesEn String?  @map("editorial_notes_en") @db.Text
  editorialNotesTr String?  @map("editorial_notes_tr") @db.Text
  parentId        String?   @map("parent_id") @db.Uuid
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz(6)

  parent          FishSpecies?           @relation("FishSpeciesHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children        FishSpecies[]          @relation("FishSpeciesHierarchy")
  lureLinks       LureSpecies[]
  scientificNameRecord SpeciesScientificName?
  commonNames     SpeciesCommonName[]
  aliases         SpeciesAlias[]
  confusions      SpeciesConfusion[] @relation("SpeciesConfusionPrimary")
  confusedBy      SpeciesConfusion[] @relation("SpeciesConfusionTarget")
  catchReports    CatchReport[]
  knowledgeItems  KnowledgeItem[]
