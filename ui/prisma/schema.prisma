/// Balık Oltamda editorial notes — never overwritten by manufacturer imports.
model LureEditorNote {
  id                    String               @id @default(uuid()) @db.Uuid
  lureModelId           String               @unique @map("lure_model_id") @db.Uuid
  shortRecommendationEn String?              @map("short_recommendation_en") @db.Text
  shortRecommendationTr String?              @map("short_recommendation_tr") @db.Text
  longRecommendationEn  String?              @map("long_recommendation_en") @db.Text
  longRecommendationTr  String?              @map("long_recommendation_tr") @db.Text
  mediterraneanNotesEn  String?              @map("mediterranean_notes_en") @db.Text
  mediterraneanNotesTr  String?              @map("mediterranean_notes_tr") @db.Text
  aegeanNotesEn         String?              @map("aegean_notes_en") @db.Text
  aegeanNotesTr         String?              @map("aegean_notes_tr") @db.Text
  northernCyprusNotesEn String?              @map("northern_cyprus_notes_en") @db.Text
  northernCyprusNotesTr String?              @map("northern_cyprus_notes_tr") @db.Text
  currentRecommendationEn String?            @map("current_recommendation_en") @db.Text
  currentRecommendationTr String?            @map("current_recommendation_tr") @db.Text
  seasonalityEn         String?              @map("seasonality_en") @db.Text
  seasonalityTr         String?              @map("seasonality_tr") @db.Text
  weatherEn             String?              @map("weather_en") @db.Text
  weatherTr             String?              @map("weather_tr") @db.Text
  waterClarityEn        String?              @map("water_clarity_en") @db.Text
  waterClarityTr        String?              @map("water_clarity_tr") @db.Text
  retrieveSpeedEn       String?              @map("retrieve_speed_en") @db.Text
  retrieveSpeedTr       String?              @map("retrieve_speed_tr") @db.Text
  bestTargetSpeciesEn   String?              @map("best_target_species_en") @db.Text
  bestTargetSpeciesTr   String?              @map("best_target_species_tr") @db.Text
  personalObservationsEn String?             @map("personal_observations_en") @db.Text
  personalObservationsTr String?             @map("personal_observations_tr") @db.Text
  recommendedRetrieveEn String?              @map("recommended_retrieve_en") @db.Text
  recommendedRetrieveTr String?              @map("recommended_retrieve_tr") @db.Text
  warningsEn            String?              @map("warnings_en") @db.Text
  warningsTr            String?              @map("warnings_tr") @db.Text
  bestColorsEn          String?              @map("best_colors_en") @db.Text
  bestColorsTr          String?              @map("best_colors_tr") @db.Text
  confidence            EditorNoteConfidence @default(MEDIUM)
  /// Internal staff notes — never exposed on the public site.
  internalNotes         String?              @map("internal_notes") @db.Text
  createdAt             DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)

  lureModel LureModel @relation(fields: [lureModelId], references: [id], onDelete: Cascade)

  @@map("lure_editor_notes")
}

/// Manufacturer import run — powers Studio Import Center and audit trail.
model ImportBatch {
  id                 String            @id @default(uuid()) @db.Uuid
  manufacturerId     String?           @map("manufacturer_id") @db.Uuid
  manufacturerCode   String            @map("manufacturer_code") @db.VarChar(64)
  displayName        String            @map("display_name") @db.VarChar(128)
  status             ImportBatchStatus @default(RUNNING)
  startedAt          DateTime          @map("started_at") @db.Timestamptz(6)
  completedAt        DateTime?         @map("completed_at") @db.Timestamptz(6)
  durationMs         Int?              @map("duration_ms")
  productsProcessed  Int               @default(0) @map("products_processed")
  createdCount       Int               @default(0) @map("created_count")
  updatedCount       Int               @default(0) @map("updated_count")
  skippedCount       Int               @default(0) @map("skipped_count")
  removedCount       Int               @default(0) @map("removed_count")
  missingCount       Int               @default(0) @map("missing_count")
  warningCount       Int               @default(0) @map("warning_count")
  errorCount         Int               @default(0) @map("error_count")
  reportPath         String?           @map("report_path") @db.VarChar(1024)
  reportJson         Json?             @map("report_json")
  createdAt          DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)

  manufacturer         Manufacturer?      @relation(fields: [manufacturerId], references: [id], onDelete: SetNull)
  importFieldChanges   ImportFieldChange[]

  @@index([manufacturerCode])
  @@index([manufacturerId])
  @@index([startedAt(sort: Desc)])
  @@index([status])
  @@map("import_batches")
}

/// Importer field diff — surfaced in Studio for accept/reject workflow.
model ImportFieldChange {
  id             String                  @id @default(uuid()) @db.Uuid
  lureModelId    String                  @map("lure_model_id") @db.Uuid
  importBatchId  String?                 @map("import_batch_id") @db.Uuid
  fieldKey       String                  @map("field_key") @db.VarChar(64)
  fieldLabel     String                  @map("field_label") @db.VarChar(128)
  oldValue       String?                 @map("old_value") @db.Text
  newValue       String?                 @map("new_value") @db.Text
  status         ImportFieldChangeStatus @default(PENDING)
  createdAt      DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  resolvedAt     DateTime?               @map("resolved_at") @db.Timestamptz(6)

  lureModel   LureModel           @relation(fields: [lureModelId], references: [id], onDelete: Cascade)
  importBatch ImportBatch?        @relation(fields: [importBatchId], references: [id], onDelete: SetNull)
  suggestion  CatalogSuggestion?

  @@index([lureModelId, status])
  @@index([importBatchId])
  @@index([createdAt(sort: Desc)])
  @@map("import_field_changes")
}

/// Editorial verification suggestion — approve, reject, correct, or merge instead of typing.
model CatalogSuggestion {
  id                  String               @id @default(uuid()) @db.Uuid
  lureModelId         String               @map("lure_model_id") @db.Uuid
  kind                SuggestionKind       @default(FIELD_VALUE)
  fieldKey            String?              @map("field_key") @db.VarChar(64)
  fieldLabel          String               @map("field_label") @db.VarChar(128)
  currentValue        String?              @map("current_value") @db.Text
  suggestedValue      String?              @map("suggested_value") @db.Text
  confidence          EditorNoteConfidence @default(MEDIUM)
  source              SuggestionSource
  reasoning           String?              @db.Text
  provenance          Json?
  status              SuggestionStatus     @default(PENDING)
  importFieldChangeId String?              @unique @map("import_field_change_id") @db.Uuid
  createdAt           DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  resolvedAt          DateTime?            @map("resolved_at") @db.Timestamptz(6)
  resolvedBy          String?              @map("resolved_by") @db.VarChar(128)

  lureModel         LureModel          @relation(fields: [lureModelId], references: [id], onDelete: Cascade)
  importFieldChange ImportFieldChange? @relation(fields: [importFieldChangeId], references: [id], onDelete: SetNull)

  @@index([lureModelId, status])
  @@index([source, status])
  @@index([createdAt(sort: Desc)])
  @@map("catalog_suggestions")
}

/// Append-only catalog change log for Studio history views.
model CatalogAuditEntry {
  id          String             @id @default(uuid()) @db.Uuid
  lureModelId String?            @map("lure_model_id") @db.Uuid
  entityType  String             @map("entity_type") @db.VarChar(64)
  entityId    String             @map("entity_id") @db.Uuid
  action      CatalogAuditAction @map("action")
  actor       String             @default("local-admin") @db.VarChar(128)
  summary     String             @db.VarChar(512)
  metadata    Json?
  createdAt   DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)

  lureModel LureModel? @relation(fields: [lureModelId], references: [id], onDelete: SetNull)

  @@index([lureModelId, createdAt(sort: Desc)])
  @@index([action])
  @@index([createdAt(sort: Desc)])
  @@map("catalog_audit_entries")
}

// ---------------------------------------------------------------------------
// Catch Reports (Sprint 7.3 — angler field experiences)
// ---------------------------------------------------------------------------

/// Angler-submitted catch report — real fishing experience, not editorial content.
model CatchReport {
  id                 String                        @id @default(uuid()) @db.Uuid
  userId             String?                       @map("user_id") @db.Uuid
  fishSpeciesId      String                        @map("fish_species_id") @db.Uuid
  lureVariantId      String                        @map("lure_variant_id") @db.Uuid
  techniqueId        String?                       @map("technique_id") @db.Uuid
  country            String                        @db.Char(2)
  region             String                        @db.VarChar(128)
  location           String?                       @db.VarChar(256)
  month              Int
  year               Int
  boatOrShore        BoatOrShore                   @map("boat_or_shore")
  waterDepthM        Decimal?                      @map("water_depth_m") @db.Decimal(6, 2)
  lureDepthM         Decimal?                      @map("lure_depth_m") @db.Decimal(6, 2)
  trollingSpeedKn    Decimal?                      @map("trolling_speed_kn") @db.Decimal(5, 2)
  catchCount         Int                           @default(1) @map("catch_count")
  largestLengthCm    Decimal?                      @map("largest_length_cm") @db.Decimal(6, 2)
  largestWeightG     Decimal?                      @map("largest_weight_g") @db.Decimal(8, 2)
  photoCount         Int                           @default(0) @map("photo_count")
  notes              String?                       @db.Text
  verificationStatus CatchReportVerificationStatus @default(PENDING) @map("verification_status")
  mergedIntoId       String?                       @map("merged_into_id") @db.Uuid
  createdAt          DateTime                      @default(now()) @map("created_at") @db.Timestamptz(6)

  fishSpecies  FishSpecies   @relation(fields: [fishSpeciesId], references: [id], onDelete: Restrict)
  lureVariant  LureVariant   @relation(fields: [lureVariantId], references: [id], onDelete: Restrict)
  technique    Technique?    @relation(fields: [techniqueId], references: [id], onDelete: SetNull)
  mergedInto   CatchReport?  @relation("CatchReportMerge", fields: [mergedIntoId], references: [id], onDelete: SetNull)
  mergedFrom   CatchReport[] @relation("CatchReportMerge")

  @@index([verificationStatus, createdAt(sort: Desc)])
  @@index([fishSpeciesId, verificationStatus])
  @@index([lureVariantId, verificationStatus])
  @@index([mergedIntoId])
  @@map("catch_reports")
}

// ---------------------------------------------------------------------------
// Knowledge Pipeline (Sprint 7.4 — acquisition architecture, no crawlers)
// ---------------------------------------------------------------------------

/// Registry of trustworthy knowledge sources — manufacturers, forums, publications, etc.
model KnowledgeSource {
  id         String              @id @default(uuid()) @db.Uuid
  slug       String              @unique @db.VarChar(128)
  sourceType KnowledgeSourceType @map("source_type")
  nameEn     String              @map("name_en") @db.VarChar(256)
  nameTr     String              @map("name_tr") @db.VarChar(256)
  baseUrl    String?             @map("base_url") @db.VarChar(1024)
  /// Editorial trust tier 1 (lowest) – 5 (highest).
  trustTier  Int                 @default(3) @map("trust_tier")
  active     Boolean             @default(true)
  createdAt  DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)

  items KnowledgeItem[]

  @@index([sourceType])
  @@index([active])
  @@map("knowledge_sources")
}

/// Discovered knowledge awaiting editorial verification.
/// TrollMatch is a knowledge index — not a content mirror. We store metadata,
/// URL, title, AI-generated summary, and catalog links. Media stays on the
/// original platform; users are directed to the source when possible.
model KnowledgeItem {
  id                String                  @id @default(uuid()) @db.Uuid
  knowledgeSourceId String                  @map("knowledge_source_id") @db.Uuid
  externalKey       String?                 @map("external_key") @db.VarChar(256)
  url               String                  @db.VarChar(2048)
  titleEn           String?                 @map("title_en") @db.VarChar(512)
  titleTr           String?                 @map("title_tr") @db.VarChar(512)
  /// Internal discovery fingerprint for dedup/matching — never shown publicly.
  rawSnippetEn      String?                 @map("raw_snippet_en") @db.Text
  rawSnippetTr      String?                 @map("raw_snippet_tr") @db.Text
  discoveredAt      DateTime                @map("discovered_at") @db.Timestamptz(6)
  confidence        KnowledgeConfidence     @default(MEDIUM)
  status            KnowledgeItemStatus     @default(PENDING_REVIEW)
  editorDecision    KnowledgeEditorDecision @default(NONE) @map("editor_decision")
  /// AI-generated summary — the only user-facing prose we store from external sources.
  aiSummaryEn       String?                 @map("ai_summary_en") @db.Text
  aiSummaryTr       String?                 @map("ai_summary_tr") @db.Text
  /// Short synthesized preview for Studio — never copied third-party text.
  sourcePreviewEn   String?                 @map("source_preview_en") @db.VarChar(512)
  sourcePreviewTr   String?                 @map("source_preview_tr") @db.VarChar(512)
  /// Primary language of the source content: en, tr, or both.
  language          String?                 @db.VarChar(8)
  country           String?                 @db.Char(2)
  region            String?                 @db.VarChar(128)
  fishSpeciesId     String?                 @map("fish_species_id") @db.Uuid
  lureModelId       String?                 @map("lure_model_id") @db.Uuid
  techniqueId       String?                 @map("technique_id") @db.Uuid
  manufacturerId    String?                 @map("manufacturer_id") @db.Uuid
  mergedIntoId      String?                 @map("merged_into_id") @db.Uuid
  reviewedAt        DateTime?               @map("reviewed_at") @db.Timestamptz(6)
  reviewedBy        String?                 @map("reviewed_by") @db.VarChar(128)
  createdAt         DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime                @updatedAt @map("updated_at") @db.Timestamptz(6)

  source       KnowledgeSource       @relation(fields: [knowledgeSourceId], references: [id], onDelete: Restrict)
  fishSpecies  FishSpecies?          @relation(fields: [fishSpeciesId], references: [id], onDelete: SetNull)
  lureModel    LureModel?            @relation(fields: [lureModelId], references: [id], onDelete: SetNull)
  technique    Technique?            @relation(fields: [techniqueId], references: [id], onDelete: SetNull)
  manufacturer Manufacturer?       @relation(fields: [manufacturerId], references: [id], onDelete: SetNull)
  mergedInto   KnowledgeItem?        @relation("KnowledgeItemMerge", fields: [mergedIntoId], references: [id], onDelete: SetNull)
  mergedFrom   KnowledgeItem[]       @relation("KnowledgeItemMerge")
  evidence     KnowledgeEvidence[]
  suggestions  KnowledgeSuggestion[]
  graphLinks   KnowledgeGraphLink[]
  auditEntries KnowledgeAuditEntry[]

  @@index([status, confidence, discoveredAt(sort: Desc)])
  @@index([knowledgeSourceId])
  @@index([fishSpeciesId])
  @@index([lureModelId])
  @@index([mergedIntoId])
  @@map("knowledge_items")
}

/// Editor reference pointer — label + URL only. No third-party excerpt republishing.
model KnowledgeEvidence {
  id              String               @id @default(uuid()) @db.Uuid
  knowledgeItemId String               @map("knowledge_item_id") @db.Uuid
  label           String               @db.VarChar(256)
  /// Optional editor note — must be synthesized, never copied source text.
  excerptEn       String               @map("excerpt_en") @db.Text
  excerptTr       String?              @map("excerpt_tr") @db.Text
  sourceUrl       String?              @map("source_url") @db.VarChar(2048)
  confidence      KnowledgeConfidence?
  sortOrder       Int                  @default(0) @map("sort_order")
  createdAt       DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)

  knowledgeItem KnowledgeItem @relation(fields: [knowledgeItemId], references: [id], onDelete: Cascade)

  @@index([knowledgeItemId])
  @@map("knowledge_evidence")
}

/// Editorial suggestion derived from a knowledge item (catalog impact).
model KnowledgeSuggestion {
  id               String              @id @default(uuid()) @db.Uuid
  knowledgeItemId  String              @map("knowledge_item_id") @db.Uuid
  kind             String              @db.VarChar(64)
  proposedValueEn  String?             @map("proposed_value_en") @db.Text
  proposedValueTr  String?             @map("proposed_value_tr") @db.Text
  targetEntityType String?             @map("target_entity_type") @db.VarChar(64)
  targetEntityId   String?             @map("target_entity_id") @db.Uuid
  status           KnowledgeItemStatus @default(PENDING_REVIEW)
  createdAt        DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)

  knowledgeItem KnowledgeItem @relation(fields: [knowledgeItemId], references: [id], onDelete: Cascade)

  @@index([knowledgeItemId])
  @@index([status])
  @@map("knowledge_suggestions")
}

/// Knowledge graph edge — preparation for future AI reasoning.
model KnowledgeGraphLink {
  id              String                     @id @default(uuid()) @db.Uuid
  knowledgeItemId String                     @map("knowledge_item_id") @db.Uuid
  entityType      KnowledgeGraphEntityType   @map("entity_type")
  entityId        String                     @map("entity_id") @db.Uuid
  relationKind    KnowledgeGraphRelationKind @map("relation_kind")
  weight          Decimal?                   @db.Decimal(4, 3)
  createdAt       DateTime                   @default(now()) @map("created_at") @db.Timestamptz(6)

  knowledgeItem KnowledgeItem @relation(fields: [knowledgeItemId], references: [id], onDelete: Cascade)

  @@index([knowledgeItemId])
  @@index([entityType, entityId])
  @@map("knowledge_graph_links")
}

/// Append-only audit log for knowledge inbox editorial actions.
model KnowledgeAuditEntry {
  id              String               @id @default(uuid()) @db.Uuid
  knowledgeItemId String?              @map("knowledge_item_id") @db.Uuid
  action          KnowledgeAuditAction
  actor           String               @default("local-admin") @db.VarChar(128)
  summary         String               @db.VarChar(512)
  metadata        Json?
  createdAt       DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)

  knowledgeItem KnowledgeItem? @relation(fields: [knowledgeItemId], references: [id], onDelete: SetNull)

  @@index([knowledgeItemId, createdAt(sort: Desc)])
  @@index([action])
  @@map("knowledge_audit_entries")
}

// ---------------------------------------------------------------------------
// Production stability — runtime error log (Studio /studio/errors)
// ---------------------------------------------------------------------------

model RuntimeErrorLog {
  id         String    @id @default(uuid()) @db.Uuid
  page       String    @db.VarChar(512)
  slug       String?   @db.VarChar(256)
  operation  String?   @map("operation") @db.VarChar(128)
  message    String    @db.VarChar(1024)
  stack      String?   @db.Text
  resolved   Boolean   @default(false)
  resolvedAt DateTime? @map("resolved_at") @db.Timestamptz(6)
  resolvedBy String?   @map("resolved_by") @db.VarChar(128)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([resolved, createdAt(sort: Desc)])
  @@index([page])
  @@map("runtime_error_logs")
}
